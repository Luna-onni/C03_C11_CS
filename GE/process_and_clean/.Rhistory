group_by(inner_number, Item, Itemtype, participant) %>%
slice_max(cloze_probability, n = 1, with_ties = FALSE) %>%
select(inner_number, Item, Itemtype, cloze_clean, cloze_probability)
View(highest_cloze_llms)
